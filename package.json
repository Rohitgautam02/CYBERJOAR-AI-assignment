{
  "name": "cyberjoar-intel-suite",
  "private": true,
  "workspaces": [
    "ps1-fusion-dashboard",
    "ps5-electoral-matrix"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=ps1-fusion-dashboard/frontend && npm install --workspace=ps1-fusion-dashboard/backend && npm install --workspace=ps5-electoral-matrix",
    "dev:ps1-front": "npm run dev --workspace=ps1-fusion-dashboard/frontend",
    "dev:ps1-back": "npm run dev --workspace=ps1-fusion-dashboard/backend",
    "dev:ps5": "npm run dev --workspace=ps5-electoral-matrix",
    "build:ps1": "npm run build --workspace=ps1-fusion-dashboard/frontend",
    "build:ps5": "npm run build --workspace=ps5-electoral-matrix"
  }
}
